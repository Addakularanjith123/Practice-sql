WITH item_sales AS ( --generated by each item in each month.
    SELECT
        EXTRACT(MONTH FROM invoicedate) AS month,
        description,
        SUM(quantity * unitprice) AS total_paid
    FROM online_retail
    WHERE invoiceno NOT LIKE 'C%'
    GROUP BY
        EXTRACT(MONTH FROM invoicedate),
        description
),
ranked_sales AS (  --Rank items within each month
    SELECT
        month,
        description,
        total_paid,
        ROW_NUMBER() OVER (
            PARTITION BY month
            ORDER BY total_paid DESC
        ) AS rn
    FROM item_sales
)
SELECT
    month,
    description,
    total_paid
FROM ranked_sales
WHERE rn = 1
ORDER BY month;
