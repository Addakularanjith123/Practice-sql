WITH cte1 AS (
    SELECT manager_empl_id, AVG(salary) AS avg_reportee_sal
    FROM map_employee_hierarchy h
    INNER JOIN dim_employee e
    ON h.empl_id = e.empl_id
    GROUP BY manager_empl_id
),
cte2 AS (
    SELECT manager_empl_id, salary
    FROM map_employee_hierarchy h
    INNER JOIN dim_employee e
    ON h.manager_empl_id = e.empl_id
)
SELECT DISTINCT a.manager_empl_id, b.salary, a.avg_reportee_sal
FROM cte1 a
INNER JOIN cte2 b
ON a.manager_empl_id = b.manager_empl_id
WHERE b.salary < (2 * a.avg_reportee_sal);

