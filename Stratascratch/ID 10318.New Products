-- select * from car_launches;

SELECT company_name,
      COUNT(CASE WHEN year = 2020 THEN 1 END) - COUNT(CASE WHEN year = 2019 THEN 1 END) AS total_launch
FROM car_launches
GROUP BY company_name;

