-- -- select * from sf_employee;

WITH bonus_totals AS (
    SELECT worker_ref_id,
           SUM(bonus) AS ttl_bonus
    FROM sf_bonus
    GROUP BY worker_ref_id
)
SELECT e.employee_title,e.sex,avg(case when ttl_bonus is not null then e.salary+ttl_bonus end) as avg_compensation
FROM sf_employee e
INNER JOIN bonus_totals b
ON e.id = b.worker_ref_id
group by 1,2


