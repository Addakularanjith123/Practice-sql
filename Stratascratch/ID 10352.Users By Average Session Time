with cte as(
    select max(timestamp) as max_load,date(timestamp) as dates,user_id
    from facebook_web_log
    where action='page_load'
    group by date(timestamp),user_id
    ),
    cte2 as (
    select min(timestamp) as min_load,date(timestamp) as dated,user_id
    from facebook_web_log
    where action='page_exit'
    group by date(timestamp),user_id
    )
select c1.user_id,
-- avg(min_load-max_load) as avg_session_durations
AVG(TIMESTAMPDIFF(SECOND, c1.max_load, c2.min_load)) AS avg_session_duration
from cte c1
join cte2 c2 on c1.user_id=c2.user_id and c1.dates=c2.dated
WHERE c1.max_load < c2.min_load
group by c1.user_id

