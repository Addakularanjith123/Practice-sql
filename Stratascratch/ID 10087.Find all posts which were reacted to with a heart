-- select distinct fp.post_id,fp.poster,fp.post_text,fp.post_keywords,fp.post_date
select distinct fp.*
from facebook_posts fp
join facebook_reactions fr on fp.post_id=fr.post_id
where fr.reaction like 'heart'
