-- -- -- -- -- -- select * from orders;
SELECT 
    ROUND(100.0 * COUNT(c.address) / COUNT(*), 2) AS percent_shipable --(100.0*13(total shipable orders))/31(total orders)=1300.0/31=41.93548387 because for the floating devision.
    -- ROUND((COUNT(c.address) * 100.0) / COUNT(*),2) AS percent_shipable -- count(column) takes only column which hhas value then only it will count it won't takes not values
    -- ROUND(100.0 * SUM(CASE WHEN c.address IS NOT NULL THEN 1 ELSE 0 END) / COUNT(*),2) AS percent_shipable
    -- 100.0*SUM( CASE WHEN NULLIF(TRIM(c.address), '') IS NOT NULL THEN 1 ELSE 0 END )  / COUNT(DISTINCT o.id) AS percent_shipable  --for not consideing the empty string
FROM orders o
JOIN customers c
ON c.id = o.cust_id;






